# Environment Variables for Email Configuration

# (recommended production) SendGrid API key path:
SENDGRID_API_KEY=your-sendgrid-api-key

# (alternate production) Gmail SMTP app password path:
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password

# From/to address configuration
MAIL_FROM=noreply@yourdomain.com
EMAIL_RECIPIENT=recipient@yourdomain.com

# Local/test fallback (no email provider configured): Ethereal is used by default

# Optional: Set a custom port (default is 3000)
PORT=3000